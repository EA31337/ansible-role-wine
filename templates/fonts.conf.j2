<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "urn:fontconfig:fonts.dtd">
<fontconfig>
  <dir prefix="default">{{ wine_fontconfig_path }}/share/fonts</dir>
  <dir prefix="default">{{ wine_fontconfig_system_fonts_dir }}</dir>
  {% for item in wine_fontconfig_fonts_dirs %}
  <dir>~{{ item }}</dir>
  {% endfor %}
  <include ignore_missing="yes">{{ wine_fontconfig_path }}/etc/fonts/fonts.conf</include>

  <config>
    <rescan><int>30</int></rescan>
  </config>
</fontconfig>

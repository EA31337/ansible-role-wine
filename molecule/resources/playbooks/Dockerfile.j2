{% set base_image = item.base_image | default(item.image) %}
FROM {{ base_image }}

LABEL org.opencontainers.image.source=https://github.com/EA31337/ansible-role-wine
LABEL org.opencontainers.image.description="Wine container based on ea31337.wine Ansible role"

ENV DISPLAY=:0
ENV XDG_RUNTIME_DIR=/tmp/runtime-root

{% if 'nixos' in base_image %}

# Prepare NixOS environment: containerd workarounds, proxy CA certs, and Ansible dependencies.
COPY ca-certificates/ /tmp/host-ca/
RUN \
    # Workaround for containerd 2.2.0+ / Go 1.24 "path escapes from parent" error.
    # Convert absolute symlinks (/etc/passwd -> /nix/store/...) to relative ones.
    # See: https://github.com/containerd/containerd/issues/12683
    ln --symbolic --force "$(realpath --relative-to=/etc /etc/passwd)" /etc/passwd && \
    ln --symbolic --force "$(realpath --relative-to=/etc /etc/group)" /etc/group && \
    # Trust proxy CA certificates (files in /etc/ssl/certs/ vanish across NixOS image layers).
    # Store combined cert in /etc/nix/ and inject into Nix configuration.
    combined="/etc/nix/ca-bundle.crt" && \
    nix_bundle="/nix/var/nix/profiles/default/etc/ssl/certs/ca-bundle.crt" && \
    if ls /tmp/host-ca/*.crt >/dev/null 2>&1; then \
      mkdir -p /etc/nix && \
      cp "$nix_bundle" "$combined" && \
      for c in /tmp/host-ca/*.crt; do cat "$c" >> "$combined"; done && \
      printf "ssl-cert-file = %s\n" "$combined" >> /etc/nix/nix.conf; \
    fi && \
    rm -rf /tmp/host-ca && \
    # Install required packages for Ansible and Wine tests.
    nix-channel --update --option sandbox false > /dev/null && \
    nix-env --option sandbox false -iA \
        nixpkgs.procps \
        nixpkgs.python3 \
        nixpkgs.python3Packages.pip \
        nixpkgs.sudo \
        nixpkgs.xorg.xdpyinfo \
        nixpkgs.xvfb-run > /dev/null

{% elif 'alpine' in base_image %}

# Prepare Alpine environment: trust proxy CA certs and install Ansible/Wine dependencies.
COPY ca-certificates/ /tmp/host-ca/
RUN \
    # Trust proxy CA certificates if present (appended to live bundles for immediate use by apk).
    if ls /tmp/host-ca/*.crt >/dev/null 2>&1; then \
      mkdir -p /usr/local/share/ca-certificates && \
      cp /tmp/host-ca/*.crt /usr/local/share/ca-certificates/ && \
      # apk uses /etc/ssl/cert.pem directly in minimal Alpine images.
      for c in /tmp/host-ca/*.crt; do cat "$c" >> /etc/ssl/cert.pem; done && \
      # Keep the common OpenSSL bundle in sync when present.
      if [ -f /etc/ssl/certs/ca-certificates.crt ]; then \
        for c in /tmp/host-ca/*.crt; do cat "$c" >> /etc/ssl/certs/ca-certificates.crt; done; \
      fi; \
    fi && \
    rm -rf /tmp/host-ca && \
    # Enable community repository for some packages.
    grep -E '^[^#].*/main$' /etc/apk/repositories | sed 's/main$/community/' >> /etc/apk/repositories && \
    # Install required packages for Ansible and Wine tests.
    apk update -q && \
    apk add -q --no-cache \
        bash \
        ca-certificates \
        python3 \
        sudo \
        xauth \
        xdpyinfo \
        xvfb-run && \
    # Ensure CA certs are properly registered in the system.
    update-ca-certificates

{% endif %}

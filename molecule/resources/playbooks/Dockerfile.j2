{% set base_image = item.base_image | default(item.image) %}
{% if 'nixos' in base_image %}
FROM {{ base_image }}

# Workaround for containerd 2.2.0+ / Go 1.24 "path escapes from parent" error.
# Convert absolute symlinks (/nix/store/...) to relative ones.
# See: https://github.com/containerd/containerd/issues/12683
RUN ln --symbolic --force \
      "$(realpath --relative-to=/etc /etc/passwd)" /etc/passwd && \
    ln --symbolic --force \
      "$(realpath --relative-to=/etc /etc/group)" /etc/group

# Trust proxy CA certificates (if present on the host during build).
# Store combined cert in /etc/nix/ — files in /etc/ssl/certs/ vanish across
# Docker overlay layers in the NixOS image due to a containerd/overlayfs bug.
COPY ca-certificates/ /tmp/host-ca/
RUN combined="/etc/nix/ca-bundle.crt" && \
    nix_bundle="/nix/var/nix/profiles/default/etc/ssl/certs/ca-bundle.crt" && \
    if ls /tmp/host-ca/*.crt >/dev/null 2>&1; then \
      mkdir -p /etc/nix && \
      cp "$nix_bundle" "$combined" && \
      for c in /tmp/host-ca/*.crt; do cat "$c" >> "$combined"; done && \
      printf "ssl-cert-file = %s\n" "$combined" >> /etc/nix/nix.conf; \
    fi && \
    rm -rf /tmp/host-ca

# Install required packages for Ansible to work on NixOS.
RUN nix-channel --update && \
    nix-env -iA nixpkgs.procps nixpkgs.python3 nixpkgs.python3Packages.pip

{% endif %}
